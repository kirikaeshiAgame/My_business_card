# ─── Frontend (Vite) ────────────────────────────────────────────────────────
# Add VITE_ prefix for vars accessible in the browser (none needed currently)

# ─── Backend server ──────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# CORS — frontend URL
CORS_ORIGIN=http://localhost:5173

# Site URL (used in OpenRouter HTTP-Referer header)
SITE_URL=http://localhost:5173

# ─── Email (SMTP via Nodemailer) ─────────────────────────────────────────────
# For Gmail: enable App Passwords, use smtp.gmail.com:587
# For Yandex: smtp.yandex.ru:587
# For Mailpit (local dev): localhost:1025
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@email.com
SMTP_PASS=your_app_password

# Email where contact form submissions will be sent (portfolio owner)
OWNER_EMAIL=andrey@example.com

# ─── AI (OpenRouter) ─────────────────────────────────────────────────────────
# Get your free API key at: https://openrouter.ai/keys
# Free models available: meta-llama/llama-4-scout:free, google/gemma-3-27b-it:free
OPENROUTER_API_KEY=sk-or-v1-your_key_here
